# IdeaTesseract Environment Variables

# Google Gemini API Key (Required)
# Get one at: https://aistudio.google.com/
# You can use either GEMINI_API_KEY or VITE_GEMINI_API_KEY
GEMINI_API_KEY=
VITE_GEMINI_API_KEY=

# AdSense Configuration (Optional)
# Leave empty if not using ads
ADS_TOP_ID=
ADS_SIDEBAR_ID=
ADS_FOOTER_ID=

# Environment
NODE_ENV=development
PORT=3000
